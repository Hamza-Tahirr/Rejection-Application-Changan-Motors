# SAP S/4HANA Public Cloud Configuration
# Copy this to .env.local and fill in your actual values
SAP_BASE_URL=https://your-tenant.s4hana.cloud.sap
SAP_USERNAME=your_sap_username
SAP_PASSWORD=your_sap_password

# OData Service Paths
SAP_REJECTION_SERVICE=/sap/opu/odata/sap/YY1_REJECTION_DOC_CDS
SAP_WORKFLOW_SERVICE=/sap/opu/odata/sap/YY1_ZPXP_WF_CONFIG_CDS
